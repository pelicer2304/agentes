# =============================================================================
# Environment configuration for the WhatsApp + Evolution production deployment.
# Copy this file to `.env` and fill in real values before deploying.
#
#   cp .env.example .env
#
# The API validates these on startup (apps/api/src/config/config.schema.ts) and
# HALTS on the first missing/invalid REQUIRED variable, reporting its name,
# before binding the HTTP port. Defaults shown below are applied when the
# variable is absent or an empty string.
#
# See DEPLOYMENT.md for EasyPanel deployment steps and the webhook URL note.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# REQUIRED. PostgreSQL connection string. When running via docker-compose this
# can be left to the default below (points at the bundled `postgres` service);
# override only if you use an external database.
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/decodifica?schema=public

# Credentials/name for the bundled postgres service (used by docker-compose to
# build the default DATABASE_URL above). Change the password for production.
# NOTE: a second database named `evolution` is created automatically on first
# init (infra/postgres/init) for the Evolution API gateway.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=decodifica

# Optional. Redis connection for the per-phone rate limiter. When running via
# docker-compose this defaults to the bundled redis service. The Evolution API
# also uses this redis instance.
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# Runtime environment
# -----------------------------------------------------------------------------
# REQUIRED. One of: development | staging | production
APP_ENV=production

# REQUIRED. Public origin of the frontend (used for CORS). In EasyPanel this is
# the web service's domain, e.g. https://app.example.com
FRONTEND_URL=https://app.example.com

# REQUIRED. Publicly reachable base URL of THIS api (no trailing slash). The
# Evolution webhook URL is derived as PUBLIC_API_URL + /webhooks/evolution.
# e.g. PUBLIC_API_URL=https://api.example.com
#  ->  webhook URL = https://api.example.com/webhooks/evolution
PUBLIC_API_URL=https://api.example.com

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
# REQUIRED. Secret used to sign JWTs. Must be at least 16 characters. Use a long
# random value in production (e.g. `openssl rand -base64 48`).
JWT_SECRET=change-me-to-a-long-random-secret

# -----------------------------------------------------------------------------
# LLM provider configuration
# -----------------------------------------------------------------------------
# One of: openrouter | openai. Defaults to openrouter.
LLM_PROVIDER=openrouter

# REQUIRED when LLM_PROVIDER=openrouter. Your OpenRouter API key.
OPENROUTER_API_KEY=sk-or-...

# Optional. Override the OpenRouter base URL (must be a valid URL if set).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# REQUIRED when LLM_PROVIDER=openai. Your OpenAI API key. Leave empty when using
# openrouter.
OPENAI_API_KEY=

# Primary model name. Defaults to gpt-4o-mini.
MODEL_NAME=gpt-4o-mini

# Fallback model used when the primary model fails. Defaults to
# google/gemini-2.5-flash.
LLM_MODEL_FALLBACK=google/gemini-2.5-flash

# -----------------------------------------------------------------------------
# Evolution API configuration
# -----------------------------------------------------------------------------
# REQUIRED. Base URL the APP uses to reach Evolution. With the bundled
# docker-compose this is the INTERNAL service URL (do not change). Only override
# if Evolution runs elsewhere.
EVOLUTION_API_URL=http://evolution-api:8080

# REQUIRED. Public URL of the Evolution instance itself (its own EasyPanel
# domain). Used by Evolution as SERVER_URL (QR pairing, media links, etc.).
EVOLUTION_PUBLIC_URL=https://evolution.example.com

# REQUIRED. Evolution API key (sent server-side only as the `apikey` header;
# never exposed to clients and scrubbed to *** in logs/error outputs). This is
# the SAME key the Evolution gateway is configured with (AUTHENTICATION_API_KEY).
EVOLUTION_API_KEY=your-evolution-api-key

# REQUIRED. Name of the Evolution instance to use.
EVOLUTION_INSTANCE_NAME=decodifica

# Optional. Shared secret for verifying inbound webhook requests. When set, the
# webhook controller rejects requests whose secret does not match (401). When
# empty, secret validation is skipped.
EVOLUTION_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Bot behavior toggles
# -----------------------------------------------------------------------------
# Master auto-reply switch. true | false. Defaults to true.
BOT_AUTO_REPLY_ENABLED=true

# Pause the bot for a conversation once a human handoff is accepted.
# true | false. Defaults to true.
BOT_PAUSE_ON_HANDOFF=true

# Comma-separated list of admin WhatsApp numbers that receive the internal
# handoff summary. Empty by default.
ADMIN_WHATSAPP_NUMBERS=

# -----------------------------------------------------------------------------
# Pricing configuration
# -----------------------------------------------------------------------------
# Whether price replies present a starting-at range. true | false. Defaults to true.
PRICING_RANGE_ENABLED=true

# Starting price used in price replies. Number between 0 and 999999999.99.
# Defaults to 2500.
PRICING_STARTING_AT=2500

# Optional custom pricing text. When empty the default pricing message is used.
PRICING_TEXT=

# -----------------------------------------------------------------------------
# Host port mappings (docker-compose only)
# -----------------------------------------------------------------------------
# Port on the host mapped to the api container (container always listens on 3001).
API_PORT=3001

# Port on the host mapped to the web container (container always listens on 3000).
WEB_PORT=3000
