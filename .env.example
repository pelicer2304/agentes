# =============================================================================
# Environment configuration for the DecodificaIA WhatsApp + Evolution stack.
# Copy this file to `.env` and fill in real values before deploying.
#
#   cp .env.example .env
#
# The API validates its own variables on startup
# (apps/api/src/config/config.schema.ts) and HALTS on the first missing/invalid
# REQUIRED variable, reporting its name, before binding the HTTP port. Defaults
# shown below are applied when the variable is absent or an empty string.
#
# See DEPLOYMENT.md for EasyPanel deployment steps and the webhook URL note.
# =============================================================================

# -----------------------------------------------------------------------------
# Shared Postgres (used by BOTH the app `decodifica` DB and Evolution `evolution` DB)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
# CHANGE THIS for production. Used by the app, Evolution, and the DATABASE_URL.
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=decodifica

# REQUIRED by the API. Connection string to the app database. When using the
# bundled postgres service the default below works; override for external DBs.
DATABASE_URL=postgresql://postgres:change-me-postgres-password@postgres:5432/decodifica?schema=public

# -----------------------------------------------------------------------------
# Runtime environment (API)
# -----------------------------------------------------------------------------
# REQUIRED. One of: development | staging | production
APP_ENV=production

# REQUIRED. Public origin of the frontend (CORS). The web service's EasyPanel
# domain, e.g. https://app.example.com
FRONTEND_URL=https://app.example.com

# REQUIRED. Publicly reachable base URL of the API (its EasyPanel domain, no
# trailing slash). The Evolution webhook URL is derived as
# PUBLIC_API_URL + /webhooks/evolution (registered via the WhatsApp screen).
PUBLIC_API_URL=https://api.example.com

# REQUIRED. JWT signing secret, min 16 chars. Use a long random value, e.g.
# `openssl rand -base64 48`.
JWT_SECRET=change-me-to-a-long-random-secret

# -----------------------------------------------------------------------------
# LLM provider configuration (API)
# -----------------------------------------------------------------------------
# One of: openrouter | openai. Defaults to openrouter.
LLM_PROVIDER=openrouter
# REQUIRED when LLM_PROVIDER=openrouter.
OPENROUTER_API_KEY=sk-or-...
# Optional override.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# REQUIRED when LLM_PROVIDER=openai (leave empty when using openrouter).
OPENAI_API_KEY=
MODEL_NAME=gpt-4o-mini
LLM_MODEL_FALLBACK=google/gemini-2.5-flash

# -----------------------------------------------------------------------------
# Evolution API (WhatsApp gateway)
# -----------------------------------------------------------------------------
# REQUIRED. Shared API key: Evolution authenticates inbound calls with it AND
# the app sends it as the `apikey` header to Evolution. Use the same value in
# both places. Generate a strong random key.
EVOLUTION_API_KEY=change-me-evolution-api-key

# REQUIRED. Public URL of the Evolution service (its own EasyPanel domain),
# e.g. https://evolution.example.com . Used by Evolution as SERVER_URL (QR codes,
# media links). The APP reaches Evolution internally at http://evolution-api:8080,
# so you do NOT set EVOLUTION_API_URL here in compose.
EVOLUTION_PUBLIC_URL=https://evolution.example.com

# Name of the Evolution instance the app drives. Defaults to `decodifica`.
EVOLUTION_INSTANCE_NAME=decodifica

# Optional. Shared secret to verify inbound webhook requests. When set, the app
# rejects webhooks whose secret does not match (401). Leave empty to accept the
# Evolution global webhook without an extra secret.
EVOLUTION_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Bot behavior toggles (API)
# -----------------------------------------------------------------------------
BOT_AUTO_REPLY_ENABLED=true
BOT_PAUSE_ON_HANDOFF=true
# Comma-separated admin WhatsApp numbers that receive the internal handoff summary.
ADMIN_WHATSAPP_NUMBERS=

# -----------------------------------------------------------------------------
# Pricing configuration (API)
# -----------------------------------------------------------------------------
PRICING_RANGE_ENABLED=true
PRICING_STARTING_AT=2500
PRICING_TEXT=

# -----------------------------------------------------------------------------
# Host port mappings (docker-compose only; EasyPanel manages public ports)
# -----------------------------------------------------------------------------
API_PORT=3001
WEB_PORT=3000
