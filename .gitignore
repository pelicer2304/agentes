# Dependencies
node_modules/
**/node_modules/

# Build output
dist/
**/dist/
build/
*.tsbuildinfo
**/*.tsbuildinfo

# Environment / secrets
.env
.env.*
!.env.example
*.pem
*.key

# Prisma generated client
**/.prisma/
**/generated/

# Logs (root runtime log dir only — anchored so it does NOT match
# source folders like apps/web/src/components/logs/)
/logs/
apps/*/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Coverage / test artifacts
coverage/
**/coverage/
.nyc_output/
*.checkpoint.log
jest-*.log
web-*.log

# Editor / OS
.DS_Store
Thumbs.db
.idea/
*.swp

# Vite cache
**/.vite/

# Runtime state (mounted volumes in compose) — anchored to repo root
/state/
/.embeddings/
